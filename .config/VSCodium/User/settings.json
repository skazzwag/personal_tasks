{
    "[python]": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports": "explicit"
        },
        "notebook.codeActionsOnSave": {
            "notebook.source.fixAll": "explicit",
            "notebook.source.organizeImports": "explicit"
        },
        "editor.defaultFormatter": "charliermarsh.ruff",
    },
    "python.languageServer": "None",
    "python.terminal.activateEnvironment": false,
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "autoDocstring.docstringFormat": "numpy",
    "notebook.lineNumbers": "on",
    "notebook.formatOnSave.enabled": true,

    // Workbench customizations
    "workbench.activityBar.location": "default",

    // Editor changes
    "editor.wordWrap": "on",
    "editor.minimap.enabled": false,
    "editor.hover.enabled": "off",  // disable hover-on-mouse-over, trigger with Ctrl + k then Ctrl + i
    "editor.parameterHints.enabled": false,

    // never persist Find widget history (defaults to "workspace")
    "editor.find.history": "never",
    // never persist Replace widget history (defaults to "workspace")
    "editor.find.replaceHistory": "never",
    "editor.find.seedSearchStringFromSelection": "never",
    "editor.find.autoFindInSelection": "never",
    "editor.find.globalFindClipboard": false,


    // Explorer changes
    "explorer.autoReveal": false,

    // File saving changes
    "files.trimTrailingWhitespace": true,
    "files.autoSave": "afterDelay",

    // GitHub Copilot
    "editor.inlineSuggest.enabled": false,

    // Start integrated terminal as login shell
    "terminal.integrated.profiles.linux": {
        "bash": {
            "path": "bash",
            "args": ["-l"]
        }
    },
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.enablePersistentSessions": false,
    "editor.fontFamily": "FiraMono Nerd Font Mono",
    "editor.fontSize": 18,
    "terminal.integrated.suggest.enabled": false,
    "workbench.editorAssociations": {
        "*.parquet": "duckdb.dataFileViewer",
        "*.csv": "duckdb.dataFileViewer",
        "*.tsv": "duckdb.dataFileViewer",
        "*.xlsx": "duckdb.dataFileViewer"
    },
    "security.workspace.trust.untrustedFiles": "open"
}