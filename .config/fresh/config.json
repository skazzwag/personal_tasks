{
    "theme": "builtin://terminal",
    "file_browser": {
        "show_hidden": true
    },
    "file_explorer": {
        "show_gitignored": true,
        "show_hidden": true
    },
    "editor": {
        "highlight_current_column": true,
        "auto_save_enabled": true
    },
    "plugins": {
        "git_explorer": {
            "settings": {
                "colorNames": true
            }
        }
    },
    "version": 1,
    "lsp_enabled": true,
    "lsp": {
        "python": [
            {
                "name": "ruff",
                "command": "ruff",
                "args": ["server"],
                "enabled": true,
                "root_markers": [
                    "pyproject.toml",
                    "ruff.toml",
                    ".ruff.toml",
                    ".git"
                ],
                "only_features": [
                    "diagnostics",
                    "code_action",
                    "format"
                ]
            },
            {
                "name": "ty",
                "command": "ty",
                "args": ["server"],
                "enabled": true,
                "root_markers": [
                    "pyproject.toml",
                    "ty.toml",
                    ".git"
                ],
                "except_features": [
                    "format"
                ]
            }
        ],
        "sql": {
            "name": "dbt",
            "command": "dbt-language-server",
            "args": [],
            "enabled": true,
            "root_markers": [
                "dbt_project.yml"
            ],
            "only_features": [
                "completion",
                "hover",
                "definition",
                "references"
            ]
        },
        "yaml": {
            "name": "dbt",
            "command": "dbt-language-server",
            "args": [],
            "enabled": true,
            "root_markers": [
                "dbt_project.yml"
            ],
            "only_features": [
                "completion",
                "hover",
                "definition",
                "references"
            ]
        }
    },
    "languages": {
        "python": {
            "format_on_save": true
        },
        "sql": {
            "format_on_save": false,
            "tab_size": 4
        },
        "yaml": {
            "tab_size": 2
        }
    },
    "keybindings": [
        {
          "key": "w",
          "modifiers": [
            "ctrl",
            "alt"
          ],
          "action": "close_all_buffers",
          "when": "normal"
        },
        {
          "key": "p",
          "modifiers": [
            "ctrl",
            "alt"
          ],
          "action": "quick_open_files",
          "when": "global"
        },
        {
          "key": "-",
          "modifiers": [
            "alt"
          ],
          "action": "decrease_split_size"
        },
        {
          "key": "=",
          "modifiers": [
            "alt"
          ],
          "action": "increase_split_size"
        },
        {
          "key": "v",
          "modifiers": [
            "ctrl",
            "alt"
          ],
          "action": "split_vertical"
        },
        {
          "key": "w",
          "modifiers": [
            "ctrl"
          ],
          "action": "close_tab",
          "when": "normal"
        },
        {
          "key": "d",
          "modifiers": [
            "ctrl",
            "alt"
          ],
          "action": "select_word",
          "when": "normal"
        }
    ]
}
